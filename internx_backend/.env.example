# Django
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=.railway.app,localhost,127.0.0.1

# PostgreSQL
# Local development:
DB_NAME=internx_db
DB_USER=internx_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5433
# Railway / hosted Postgres:
# Use the PUBLIC Railway connection string here.
# Do not use a private/internal host such as `postgres.railway.internal` on Vercel.
DATABASE_URL=
PGDATABASE=
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=

# Redis — start with: brew services start redis
REDIS_URL=redis://localhost:6379/0

# Celery
# For Vercel-only deployments without a worker, leave these empty or point them at a real Redis service.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email
# For LOCAL DEV (prints emails to terminal — no SMTP needed):
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For PRODUCTION (Gmail SMTP):
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=InternX <your-email@gmail.com>

# Google Calendar API
# Use the OAuth client secret JSON downloaded from Google Cloud.
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
GOOGLE_CALENDAR_CLIENT_SECRET_PATH=credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=google_calendar_token.json
GOOGLE_CALENDAR_REDIRECT_URI=http://127.0.0.1:8000
GOOGLE_CALENDAR_ID=primary

# Frontend URL (used in certificate QR codes + CORS/CSRF)
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://*.vercel.app,https://*.railway.app
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$,^https://.*\.railway\.app$

# Media files
MEDIA_URL=/media/
MEDIA_ROOT=media/
