# Django
SECRET_KEY=internx-super-secret-key-change-this-in-production-2024
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=internx_db
DB_USER=internx_user
DB_PASSWORD=internx123
