# Google Calendar API (optional — leave as-is for local dev)
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json

# Frontend URL (for certificate verification QR codes)
FRONTEND_URL=http://localhost:5173

# Media files
MEDIA_URL=/media/
